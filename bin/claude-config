#!/bin/bash
#
# Claude-config CLI.
#
# Manual overrides for projects that setup.sh skips (non-site, personal,
# module, etc.) or that you want removed without waiting for install to re-run.
#
# Usage:
#   claude-config add <project>     # wire up shared claude-config for a project
#   claude-config remove <project>  # remove shared claude-config from a project
#   claude-config help              # show this help
#
# <project> is the directory name inside your projects directory (the one
# captured during install, stored in ~/claude-config/.config).
#

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
source "$REPO_DIR/utils.sh"

CONFIG_FILE="$REPO_DIR/.config"

die() {
  echo "Error: $*" >&2
  exit 1
}

usage() {
  cat <<'EOF'
Usage: claude-config <command> [args]

Commands:
  add <project>     Wire up shared claude-config for a project.
                    Bypasses the normal skip rules (non-site, personal, etc.)
                    and clears any .personal marker so the launchd watcher
                    won't prune on the next sweep.

  remove <project>  Remove shared claude-config from a project.
                    Prunes the CLAUDE.md import and AGENTS.md pointer, then
                    sets a .personal marker so the watcher leaves it alone
                    going forward.

  help              Show this help.

<project> is the directory name inside the projects directory configured
during install (see ~/claude-config/.config).
EOF
}

load_projects_dir() {
  [[ -f "$CONFIG_FILE" ]] || die "No config found. Run ~/claude-config/install.sh first."
  # shellcheck disable=SC1090
  source "$CONFIG_FILE"
  [[ -n "${PROJECTS_DIR:-}" ]] || die "PROJECTS_DIR is empty in $CONFIG_FILE."
  [[ -d "$PROJECTS_DIR" ]] || die "PROJECTS_DIR '$PROJECTS_DIR' does not exist."
}

resolve_project() {
  local name="$1"
  # Absolute path bypasses PROJECTS_DIR lookup — lets the test harness (and
  # power users) point at arbitrary directories without a .config.
  if [[ "$name" == /* ]] && [[ -d "$name" ]]; then
    (cd "$name" && pwd)
    return
  fi
  load_projects_dir
  local path="$PROJECTS_DIR/$name"
  [[ -d "$path" ]] || die "Project '$name' not found under $PROJECTS_DIR."
  (cd "$path" && pwd)
}

cmd_add() {
  [[ $# -eq 1 ]] || { usage; exit 1; }
  local project_dir project_name claude_md did_something=0
  project_dir=$(resolve_project "$1")
  project_name=$(basename "$project_dir")

  # .personal blocks the launchd watcher. Clear it so sweeps keep this
  # project wired up.
  if [[ -f "$project_dir/.claude/.personal" ]]; then
    rm -f "$project_dir/.claude/.personal"
    echo "  Cleared .personal marker"
    did_something=1
  fi

  claude_md="$project_dir/.claude/CLAUDE.md"
  # Legacy root-level CLAUDE.md with the import counts as already-configured.
  if [[ -f "$project_dir/CLAUDE.md" ]] && grep -qF "$CLAUDE_IMPORT_LINE" "$project_dir/CLAUDE.md" 2>/dev/null; then
    echo "  CLAUDE.md import already present at project root"
  elif add_import "$claude_md" "$CLAUDE_IMPORT_LINE"; then
    echo "  Added CLAUDE.md import"
    did_something=1
  else
    echo "  CLAUDE.md import already present"
  fi

  if add_import "$project_dir/AGENTS.md" "$AGENTS_IMPORT_LINE"; then
    echo "  Added AGENTS.md pointer"
    did_something=1
  else
    echo "  AGENTS.md pointer already present"
  fi

  if (( did_something )); then
    echo "Done. $project_name is now wired up."
  else
    echo "Nothing to do. $project_name was already wired up."
  fi
}

cmd_remove() {
  [[ $# -eq 1 ]] || { usage; exit 1; }
  local project_dir project_name did_something=0
  project_dir=$(resolve_project "$1")
  project_name=$(basename "$project_dir")

  for candidate in "$project_dir/.claude/CLAUDE.md" "$project_dir/CLAUDE.md"; do
    if prune_import "$candidate" "$CLAUDE_IMPORT_LINE"; then
      echo "  Pruned CLAUDE.md import ($candidate)"
      did_something=1
    fi
  done

  if prune_import "$project_dir/AGENTS.md" "$AGENTS_IMPORT_LINE"; then
    echo "  Pruned AGENTS.md pointer"
    did_something=1
  fi

  # .personal tells setup.sh to skip-and-prune on future sweeps.
  if [[ ! -f "$project_dir/.claude/.personal" ]]; then
    mkdir -p "$project_dir/.claude"
    touch "$project_dir/.claude/.personal"
    echo "  Added .personal marker (blocks future auto-add)"
    did_something=1
  fi

  if (( did_something )); then
    echo "Done. $project_name is no longer wired up."
  else
    echo "Nothing to do. $project_name was not wired up."
  fi
}

main() {
  [[ $# -ge 1 ]] || { usage; exit 1; }
  local cmd="$1"
  shift
  case "$cmd" in
    add) cmd_add "$@" ;;
    remove|rm) cmd_remove "$@" ;;
    help|-h|--help) usage ;;
    *) echo "Unknown command: $cmd" >&2; usage; exit 1 ;;
  esac
}

main "$@"
