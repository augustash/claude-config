# Per-site New Relic credentials for nr-pull.sh.
#
# COPY this to a site dir that lives OUTSIDE this repo and fill in real values:
#   mkdir -p ~/.config/newrelic/<site> && cp nr.env.example ~/.config/newrelic/<site>/nr.env
# NEVER put a filled-in nr.env inside vendor/augustash/claude-config — it ships to every project.
#
# NR_ACCOUNT_ID  : the number in your New Relic URL (.../accounts/<ID>/...) or on the API keys page
# NR_API_KEY     : a New Relic "User" key (starts with NRAK-), created at New Relic > user menu > API keys
# NR_APP         : APM app name; Pantheon names it "<site> (<env>)" e.g. "mspairport (live)"
# NR_ENDPOINT    : optional; defaults to US. EU accounts: https://api.eu.newrelic.com/graphql

NR_ACCOUNT_ID=
NR_API_KEY=NRAK-
NR_APP=
# NR_ENDPOINT=https://api.newrelic.com/graphql
